---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Workflow from '../components/Workflow.astro';
import Screenshots from '../components/Screenshots.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <nav class="site-nav">
    <div class="site-nav-inner">
      <a href="/" class="site-nav-brand">
        <img src="/images/app-icon-nav.png" alt="" width="28" height="28" />
        <span>FoodMapper</span>
      </a>
      <div class="site-nav-right">
        <a
          href="https://github.com/RichardStoker-USDA/FoodMapper"
          class="nav-github-link"
          aria-label="GitHub repository"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.477 0 10c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.93 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0110 4.84c.85.004 1.71.115 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.75c0 .27.16.59.67.5A10.013 10.013 0 0020 10c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
          </svg>
        </a>
        <ThemeToggle />
      </div>
    </div>
  </nav>

  <main id="main-content">
    <Hero />

    <div class="section-divider"><hr /></div>

    <div class="page-gradient">
      <Features />

      <div class="section-divider"><hr /></div>

      <Workflow />

      <div class="section-divider"><hr /></div>

      <Screenshots />
    </div>
  </main>

  <Footer />
</BaseLayout>
